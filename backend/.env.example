# Application Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# RetellAI Credentials (Required in future phases)
RETELL_API_KEY=your_retell_api_key_here
RETELL_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key_here

# Google Sheets Configuration (Required in future phases)
GOOGLE_SPREADSHEET_ID=your_google_spreadsheet_id_here
# Path to service_account.json credentials file (placed inside backend or absolute path)
GOOGLE_APPLICATION_CREDENTIALS=app/core/credentials.json

# SMTP Configuration (Required in future phases)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address_here@gmail.com
# Google App Password (not standard account password)
SMTP_PASSWORD=your_gmail_app_password_here
EMAIL_FROM=your_gmail_address_here@gmail.com
